# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase (server-only — never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=

# Admin access
ADMIN_EMAILS=your@email.com
ADMIN_COOKIE_SECRET=

# Email — Resend (https://resend.com — free tier: 3,000 emails/month)
RESEND_API_KEY=
EMAIL_FROM=StayNest <hello@yourdomain.com>
AGENT_EMAIL=your@email.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Rate limiting — Upstash Redis REST (https://console.upstash.com — free tier 10k commands/day)
# If unset, rate-limited endpoints log a warning and allow every request.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# M-Pesa Daraja (Safaricom) — https://developer.safaricom.co.ke
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://your-domain.com/api/pay/callback
MPESA_CALLBACK_SECRET=
